{
  "openapi": "3.1.0",
  "info": {
    "title": "Emumet Account Service API",
    "description": "Account Service for ShuttlePub",
    "contact": {
      "name": "turtton"
    },
    "license": {
      "name": "AGPL-3.0",
      "url": "https://www.gnu.org/licenses/agpl-3.0.html"
    },
    "version": "0.1.0"
  },
  "paths": {
    "/.well-known/webfinger": {
      "get": {
        "tags": [
          "ActivityPub"
        ],
        "description": "WebFinger account discovery for ActivityPub.",
        "operationId": "webfinger",
        "parameters": [
          {
            "name": "resource",
            "in": "query",
            "description": "Resource URI (acct:user@domain)",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "WebFinger response",
            "content": {
              "application/jrd+json": {
                "schema": {
                  "$ref": "#/components/schemas/WebFingerResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid resource format"
          },
          "404": {
            "description": "Account not found"
          }
        }
      }
    },
    "/ap/accounts/{account_id}": {
      "get": {
        "tags": [
          "ActivityPub"
        ],
        "description": "Retrieve an ActivityPub Actor document for a local account.",
        "operationId": "get_actor",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Account nanoid",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "ActivityPub Actor",
            "content": {
              "application/activity+json": {
                "schema": {
                  "$ref": "#/components/schemas/Actor"
                }
              }
            }
          },
          "404": {
            "description": "Actor not found"
          }
        }
      }
    },
    "/ap/accounts/{account_id}/followers": {
      "get": {
        "tags": [
          "ActivityPub"
        ],
        "description": "Retrieve an ActivityPub followers OrderedCollection for a local account.",
        "operationId": "get_followers",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Account nanoid",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Followers collection",
            "content": {
              "application/activity+json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderedCollection"
                }
              }
            }
          },
          "400": {
            "description": "Invalid account ID"
          },
          "404": {
            "description": "Account not found"
          }
        }
      }
    },
    "/ap/accounts/{account_id}/following": {
      "get": {
        "tags": [
          "ActivityPub"
        ],
        "description": "Retrieve an ActivityPub following OrderedCollection for a local account.",
        "operationId": "get_following",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Account nanoid",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Following collection",
            "content": {
              "application/activity+json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderedCollection"
                }
              }
            }
          },
          "400": {
            "description": "Invalid account ID"
          },
          "404": {
            "description": "Account not found"
          }
        }
      }
    },
    "/ap/accounts/{account_id}/inbox": {
      "post": {
        "tags": [
          "ActivityPub"
        ],
        "description": "ActivityPub inbox for signed inbound federation activities.",
        "operationId": "post_inbox",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Account nanoid",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/activity+json": {
              "schema": {}
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "description": "Activity accepted or ignored"
          },
          "400": {
            "description": "Malformed ActivityPub activity"
          },
          "401": {
            "description": "Missing or invalid HTTP Signature"
          },
          "404": {
            "description": "Local actor not found"
          }
        }
      }
    },
    "/ap/accounts/{account_id}/outbox": {
      "get": {
        "tags": [
          "ActivityPub"
        ],
        "description": "Retrieve an ActivityPub outbox OrderedCollection for a local account.",
        "operationId": "get_outbox",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Account nanoid",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of activities to return",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 0
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "description": "Return activities with IDs older than this cursor",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Outbox collection",
            "content": {
              "application/activity+json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderedCollection"
                }
              }
            }
          },
          "400": {
            "description": "Invalid account ID or pagination parameter"
          },
          "404": {
            "description": "Account not found"
          }
        }
      }
    },
    "/api/v1/accounts": {
      "get": {
        "tags": [
          "Account"
        ],
        "description": "Retrieve accounts by IDs or with cursor-based pagination.",
        "operationId": "get_accounts",
        "parameters": [
          {
            "name": "ids",
            "in": "query",
            "description": "Comma-separated account IDs",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Pagination limit",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 0
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "description": "Pagination cursor",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "direction",
            "in": "query",
            "description": "Pagination direction (asc/desc)",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of accounts",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccountsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters"
          },
          "404": {
            "description": "No accounts found"
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ]
      },
      "post": {
        "tags": [
          "Account"
        ],
        "description": "Create a new account with a generated signing key pair.",
        "operationId": "create_account",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateAccountRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Account created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccountResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ]
      }
    },
    "/api/v1/accounts/{account_id}": {
      "get": {
        "tags": [
          "Account"
        ],
        "description": "Retrieve one integrated account resource.",
        "operationId": "get_account_by_id",
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "description": "Account nanoid",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Integrated account",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccountResponse"
                }
              }
            }
          },
          "404": {
            "description": "Account not found"
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ]
      },
      "delete": {
        "tags": [
          "Account"
        ],
        "description": "Deactivate an account and cascade-delete related resources.",
        "operationId": "deactivate_account_by_id",
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "description": "Account nanoid",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Account deactivated"
          },
          "400": {
            "description": "Invalid request"
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ]
      },
      "patch": {
        "tags": [
          "Account"
        ],
        "description": "Update account properties.",
        "operationId": "update_account_by_id",
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "description": "Account nanoid",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateAccountRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Account updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccountResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ]
      }
    },
    "/api/v1/accounts/{account_id}/follow": {
      "post": {
        "tags": [
          "ActivityPub"
        ],
        "description": "Follow a remote ActivityPub account.",
        "operationId": "follow_account",
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "description": "Local account nanoid",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FollowAccountRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Follow initiated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FollowAccountResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "404": {
            "description": "Account not found"
          },
          "409": {
            "description": "Already following"
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ]
      }
    },
    "/api/v1/admin/accounts/{account_id}/ban": {
      "post": {
        "tags": [
          "Account"
        ],
        "description": "Permanently ban an account.",
        "operationId": "ban_account_by_id",
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "description": "Account nanoid",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BanAccountRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "204": {
            "description": "Account banned"
          },
          "400": {
            "description": "Invalid request"
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ]
      }
    },
    "/api/v1/admin/accounts/{account_id}/suspend": {
      "post": {
        "tags": [
          "Account"
        ],
        "description": "Suspend an account with a reason and optional expiry.",
        "operationId": "suspend_account_by_id",
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "description": "Account nanoid",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SuspendAccountRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "204": {
            "description": "Account suspended"
          },
          "400": {
            "description": "Invalid request"
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ]
      }
    },
    "/api/v1/admin/accounts/{account_id}/unsuspend": {
      "post": {
        "tags": [
          "Account"
        ],
        "description": "Remove suspension from an account.",
        "operationId": "unsuspend_account_by_id",
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "description": "Account nanoid",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Account unsuspended"
          },
          "400": {
            "description": "Invalid request"
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ]
      }
    },
    "/internal/v1/accounts/{id}/public-key": {
      "get": {
        "tags": [
          "Signing"
        ],
        "description": "Retrieve the public key for an account.",
        "operationId": "get_public_key",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Account nanoid",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Public key info",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicKeyResponse"
                }
              }
            }
          },
          "404": {
            "description": "Account or signing key not found"
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ]
      }
    },
    "/internal/v1/accounts/{id}/sign": {
      "post": {
        "tags": [
          "Signing"
        ],
        "description": "Sign an HTTP request using the account's signing key.",
        "operationId": "sign_request",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Account nanoid",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignRequestBody"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Signed headers",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SignResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Insufficient permissions"
          },
          "404": {
            "description": "Account or signing key not found"
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ]
      }
    },
    "/oauth2/consent": {
      "get": {
        "tags": [
          "OAuth2"
        ],
        "description": "Retrieve consent request details or auto-accept if skip is configured.",
        "operationId": "get_consent",
        "parameters": [
          {
            "name": "consent_challenge",
            "in": "query",
            "description": "Hydra consent challenge",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Consent details for user approval",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OAuth2Response"
                }
              }
            }
          },
          "302": {
            "description": "Redirect (auto-accepted or skipped)"
          },
          "502": {
            "description": "Bad gateway (Hydra error)"
          }
        }
      },
      "post": {
        "tags": [
          "OAuth2"
        ],
        "description": "Submit consent decision (accept or reject).",
        "operationId": "post_consent",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ConsentDecision"
              }
            }
          },
          "required": true
        },
        "responses": {
          "302": {
            "description": "Redirect after consent decision"
          },
          "400": {
            "description": "Invalid scope requested"
          },
          "502": {
            "description": "Bad gateway (Hydra error)"
          }
        }
      }
    },
    "/oauth2/login": {
      "get": {
        "tags": [
          "OAuth2"
        ],
        "description": "Handle OAuth2 login flow. Verifies Kratos session and accepts Hydra login.",
        "operationId": "login",
        "parameters": [
          {
            "name": "login_challenge",
            "in": "query",
            "description": "Hydra login challenge",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "302": {
            "description": "Redirect to Hydra callback"
          },
          "502": {
            "description": "Bad gateway (Hydra/Kratos error)"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AccountField": {
        "type": "object",
        "required": [
          "label",
          "content"
        ],
        "properties": {
          "content": {
            "type": "string"
          },
          "label": {
            "type": "string"
          }
        }
      },
      "AccountResponse": {
        "type": "object",
        "required": [
          "id",
          "name",
          "is_bot",
          "fields",
          "created_at"
        ],
        "properties": {
          "banner_url": {
            "type": [
              "string",
              "null"
            ]
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "display_name": {
            "type": [
              "string",
              "null"
            ]
          },
          "fields": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AccountField"
            }
          },
          "icon_url": {
            "type": [
              "string",
              "null"
            ]
          },
          "id": {
            "type": "string"
          },
          "is_bot": {
            "type": "boolean"
          },
          "moderation": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/ModerationResponse"
              }
            ]
          },
          "name": {
            "type": "string"
          },
          "summary": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "AccountsResponse": {
        "type": "object",
        "required": [
          "items"
        ],
        "properties": {
          "first": {
            "type": [
              "string",
              "null"
            ]
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AccountResponse"
            }
          },
          "last": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "Actor": {
        "type": "object",
        "description": "An ActivityPub Actor representing a local Account.\n\nSerialized as a `Person` type with public key, inbox/outbox URLs,\nand optional profile fields.",
        "required": [
          "@context",
          "id",
          "type",
          "preferredUsername",
          "url",
          "inbox",
          "outbox",
          "followers",
          "following",
          "publicKey"
        ],
        "properties": {
          "@context": {
            "type": "array",
            "items": {}
          },
          "followers": {
            "type": "string"
          },
          "following": {
            "type": "string"
          },
          "icon": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/ImageObject"
              }
            ]
          },
          "id": {
            "type": "string"
          },
          "inbox": {
            "type": "string"
          },
          "name": {
            "type": [
              "string",
              "null"
            ]
          },
          "outbox": {
            "type": "string"
          },
          "preferredUsername": {
            "type": "string"
          },
          "publicKey": {
            "$ref": "#/components/schemas/PublicKey"
          },
          "summary": {
            "type": [
              "string",
              "null"
            ]
          },
          "type": {
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        }
      },
      "BanAccountRequest": {
        "type": "object",
        "required": [
          "reason"
        ],
        "properties": {
          "reason": {
            "type": "string"
          }
        }
      },
      "ConsentDecision": {
        "type": "object",
        "required": [
          "consent_challenge",
          "accept"
        ],
        "properties": {
          "accept": {
            "type": "boolean"
          },
          "consent_challenge": {
            "type": "string"
          },
          "grant_scope": {
            "type": [
              "array",
              "null"
            ],
            "items": {
              "type": "string"
            }
          }
        }
